# App
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
# Local SQLite default: omit DATABASE_URL
# PostgreSQL (RDS/ECS/EC2) example:
DATABASE_URL=postgresql+psycopg://app_user:app_password@db-host:5432/order_automation

# Storage backend: local or s3
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads

# S3 settings (required when STORAGE_BACKEND=s3)
S3_BUCKET=your-bucket-name
S3_PREFIX=order-automation/uploads
AWS_REGION=ap-northeast-1
# Optional for CloudFront or public bucket URL
S3_PUBLIC_BASE_URL=
# Optional for localstack/dev only
AWS_ENDPOINT_URL=

# OCR pipeline
# true: enqueue OCR jobs (recommended for AWS)
# false: run OCR synchronously in API process
OCR_ASYNC_ENABLED=false
OCR_QUEUE_BACKEND=sqs
OCR_QUEUE_URL=
OCR_WORKER_WAIT_SECONDS=20
